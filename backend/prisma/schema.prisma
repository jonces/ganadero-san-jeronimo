generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  TRABAJADOR
}

enum Sexo {
  MACHO
  HEMBRA
}

enum TipoEvento {
  VACUNACION
  TRATAMIENTO
  PESAJE
  PARTO
  OBSERVACION
  MOVIMIENTO
}

enum TipoDocumento {
  FIERRO_ANUAL
  PERMISO_ALCALDIA
  CARTA_VENTA
  OTRO
}

enum TipoVenta {
  EN_PIE
  POR_PESO
}

enum MetodoPago {
  EFECTIVO
  TRANSFERENCIA
  CHEQUE
  CREDITO
}

enum EstadoPago {
  PAGADO
  PENDIENTE
  PARCIAL
}

model Finca {
  id           String   @id @default(uuid())
  nombre       String
  ubicacion    String?
  tipoCambio   Float    @default(36.5)
  activa       Boolean  @default(true)
  plan         String   @default("GRATUITO")
  createdAt    DateTime @default(now())

  usuarios    Usuario[]
  animales    Animal[]
  documentos  Documento[]
  ventas      Venta[]
  incidentes  Incidente[]
  gastos      Gasto[]
  anuncios      Anuncio[]
  actividadLogs ActividadLog[]
  tareas        Tarea[]
}

model Usuario {
  id           String   @id @default(uuid())
  nombre       String
  email        String   @unique
  passwordHash String
  role         Role     @default(TRABAJADOR)
  fincaId      String
  finca        Finca    @relation(fields: [fincaId], references: [id])
  resetCodigo  String?
  resetExpira  DateTime?
  fotoPerfil   String?
  createdAt    DateTime @default(now())

  eventos    Evento[]
  ventas     Venta[]
  incidentes Incidente[]
  gastos     Gasto[]
  anuncios      Anuncio[]
  comentarios   Comentario[]
  actividadLogs ActividadLog[]
  tareas        Tarea[]
}

model Animal {
  id              String    @id @default(uuid())
  identificador   String    @unique
  nombre          String?
  raza            String?
  fierro          String?
  sexo            Sexo
  fechaNacimiento DateTime?
  pesoActual      Float?
  observacion     String?
  estado          String    @default("ACTIVO")
  // Estado reproductivo (solo hembras)
  estadoReproductivo String? // PREÑADA, PARIDA, LACTANCIA, SECA, VACIA - sync v2
  fechaParto         DateTime?
  fechaSecado        DateTime?
  madreId            String?
  madre              Animal?   @relation("Crias", fields: [madreId], references: [id])
  crias              Animal[]  @relation("Crias")
  fincaId         String
  finca           Finca     @relation(fields: [fincaId], references: [id])
  createdAt       DateTime  @default(now())

  eventos    Evento[]
  media      Media[]
  ventas     Venta[]
  incidentes Incidente[]
  tareas     TareaAnimal[]
}

model Evento {
  id          String     @id @default(uuid())
  tipo        TipoEvento
  descripcion String?
  peso        Float?
  fecha       DateTime   @default(now())
  animalId    String
  animal      Animal     @relation(fields: [animalId], references: [id])
  usuarioId   String
  usuario     Usuario    @relation(fields: [usuarioId], references: [id])

  media Media[]
}

model Media {
  id        String   @id @default(uuid())
  url       String
  tipo      String
  animalId  String?
  animal    Animal?  @relation(fields: [animalId], references: [id])
  eventoId  String?
  evento    Evento?  @relation(fields: [eventoId], references: [id])
  ventaId      String?
  venta        Venta?     @relation(fields: [ventaId], references: [id])
  incidenteId  String?
  incidente    Incidente? @relation(fields: [incidenteId], references: [id])
  createdAt DateTime @default(now())
}

model Incidente {
  id          String   @id @default(uuid())
  tipo        String   // ACCIDENTE, ENFERMEDAD, MUERTE, OTRO
  gravedad    String   @default("LEVE") // LEVE, MODERADA, GRAVE, CRITICA
  estado      String   @default("ACTIVO") // ACTIVO, RESUELTO
  descripcion String
  tratamiento String?
  animalId    String?
  animal      Animal?  @relation(fields: [animalId], references: [id])
  fincaId     String
  finca       Finca    @relation(fields: [fincaId], references: [id])
  usuarioId   String
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])
  fecha       DateTime @default(now())
  createdAt   DateTime @default(now())
  media       Media[]
}

model Gasto {
  id           String   @id @default(uuid())
  descripcion  String
  categoria    String   // ALIMENTACION, MEDICAMENTO, MANTENIMIENTO, SALARIO, COMBUSTIBLE, OTRO
  monto        Float
  moneda       String   @default("NIO")
  periodicidad String   // DIARIO, SEMANAL, QUINCENAL, MENSUAL, UNICO
  fecha        DateTime @default(now())
  notas        String?
  fincaId      String
  finca        Finca    @relation(fields: [fincaId], references: [id])
  usuarioId    String
  usuario      Usuario  @relation(fields: [usuarioId], references: [id])
  createdAt    DateTime @default(now())
}

model Documento {
  id        String        @id @default(uuid())
  nombre    String
  tipo      TipoDocumento
  url       String
  notas     String?
  fincaId   String
  finca     Finca         @relation(fields: [fincaId], references: [id])
  createdAt DateTime      @default(now())
}

model Venta {
  id            String     @id @default(uuid())
  tipoVenta     TipoVenta
  moneda        String     @default("NIO")
  tipoCambio    Float      @default(36.5)
  precioNIO     Float
  precioUSD     Float
  pesoKg        Float?
  unidadPeso    String     @default("LB")
  precioKg      Float?
  metodoPago    MetodoPago @default(EFECTIVO)
  estadoPago    EstadoPago @default(PAGADO)
  numeroFactura String?
  comision      Float?
  descuento     Float?
  impuestos     Float?
  comprador     String?
  telefonoComprador String?
  direccionComprador String?
  notas         String?
  fecha         DateTime   @default(now())
  animalId      String
  animal        Animal     @relation(fields: [animalId], references: [id])
  fincaId       String
  finca         Finca      @relation(fields: [fincaId], references: [id])
  usuarioId     String
  usuario       Usuario    @relation(fields: [usuarioId], references: [id])
  createdAt     DateTime   @default(now())

  media         Media[]
}

model Anuncio {
  id          String       @id @default(uuid())
  titulo      String
  mensaje     String
  emoji       String       @default("📢")
  fincaId     String
  finca       Finca        @relation(fields: [fincaId], references: [id])
  autorId     String
  autor       Usuario      @relation(fields: [autorId], references: [id])
  comentarios Comentario[]
  createdAt   DateTime     @default(now())
}

model Comentario {
  id         String   @id @default(uuid())
  mensaje    String
  anuncioId  String
  anuncio    Anuncio  @relation(fields: [anuncioId], references: [id], onDelete: Cascade)
  autorId    String
  autor      Usuario  @relation(fields: [autorId], references: [id])
  createdAt  DateTime @default(now())
}

model Tarea {
  id          String        @id @default(uuid())
  tipo        String        // VACUNACION, TRATAMIENTO, DESPARASITACION, PESAJE, INSEMINACION, DESTETE, OTRO
  descripcion String?
  fecha       DateTime
  estado      String        @default("PENDIENTE") // PENDIENTE, COMPLETADA
  fincaId     String
  finca       Finca         @relation(fields: [fincaId], references: [id])
  creadoPor   String
  creador     Usuario       @relation(fields: [creadoPor], references: [id])
  animales    TareaAnimal[]
  createdAt   DateTime      @default(now())
}

model TareaAnimal {
  id       String @id @default(uuid())
  tareaId  String
  tarea    Tarea  @relation(fields: [tareaId], references: [id], onDelete: Cascade)
  animalId String
  animal   Animal @relation(fields: [animalId], references: [id])
}

model ActividadLog {
  id        String   @id @default(uuid())
  accion    String
  detalle   String?
  modulo    String
  fincaId   String
  finca     Finca    @relation(fields: [fincaId], references: [id])
  usuarioId String
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  createdAt DateTime @default(now())
}
